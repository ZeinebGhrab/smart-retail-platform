# URL de base de l'API Django (backend/django_api)
VITE_API_URL=http://localhost:8000/api

# API Backend
VITE_API_URL=http://localhost:8000/api
 
# ============================================================
# Firebase Configuration
# Obtenir ces valeurs depuis Firebase Console
# ============================================================
 
# Clé API Firebase (publique)
REACT_APP_FIREBASE_API_KEY=AIzaSyC...
 
# Domaine d'authentification
REACT_APP_FIREBASE_AUTH_DOMAIN=anavid-91d01.firebaseapp.com
 
# ID du projet Firebase
REACT_APP_FIREBASE_PROJECT_ID=anavid-91d01
 
# Bucket de stockage
REACT_APP_FIREBASE_STORAGE_BUCKET=anavid-91d01.appspot.com
 
# ID d'envoi des messages (Sender ID)
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=1234567890
 
# ID de l'application
REACT_APP_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
 
# ============================================================
# Firebase Cloud Messaging (FCM)
# ============================================================
 
# VAPID Key pour les notifications push (Web)
# Obtenir depuis Firebase Console → Cloud Messaging → Web Configuration
REACT_APP_FIREBASE_VAPID_KEY=BCxx...zz
 
# ============================================================
# Guide: Comment obtenir ces valeurs
# ============================================================
 
# 1. Aller sur https://console.firebase.google.com/
# 2. Sélectionner le projet "anavid-91d01"
# 3. Cliquer sur l'icône engrenage → Project Settings
# 4. Onglet "General" → copier firebaseConfig (Web)
# 5. Pour la VAPID Key:
#    - Onglet "Cloud Messaging"
#    - Section "Web configuration"
#    - Copier la "VAPID key" ou "Server Key"
# 6. Remplir les valeurs ci-dessus
 
# ============================================================
# Vérification
# ============================================================
 
# Les variables doivent être prefixées par:
# - REACT_APP_ (pour les apps Create React App)
# - VITE_ (pour les apps Vite)
 
# Vérifier dans console du navigateur:
# console.log(process.env.REACT_APP_FIREBASE_API_KEY)
# Devrait afficher la clé (non-vide)