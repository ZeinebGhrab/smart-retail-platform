# ============================================================
# .gitignore — Anavid Smart Retail Platform
# ============================================================

# ── Variables d'environnement (secrets) ─────────────────────
.env
.env.*
!.env.example

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Django ──────────────────────────────────────────────────
*.sqlite3
/staticfiles/
/mediafiles/

# ── Node / Frontend ─────────────────────────────────────────
node_modules/
dist/
.vite/
*.local

# ── Docker ──────────────────────────────────────────────────
*.log

# ── OS ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo